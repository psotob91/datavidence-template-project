# .gitattributes (factory repo) — normalize line endings, mark binaries.
# https://git-scm.com/docs/gitattributes

# Auto-detect text and normalize to LF in the repository.
* text=auto

# --- Enforce platform-correct endings ------------------------------------
*.py     text eol=lf
*.sh     text eol=lf
*.jinja  text eol=lf
*.ps1    text eol=crlf
*.bat    text eol=crlf

# --- Binary assets (never diff, never normalize) -------------------------
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.mhtml binary
*.xlsx binary
