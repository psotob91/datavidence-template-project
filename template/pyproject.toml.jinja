[project]
name = "{{ project_slug }}"
version = "0.0.0"
description = "Reproducible analysis project for {{ project_name }}."
authors = [{ name = "{{ author }}" }]
license = { text = "{{ license }}" }
readme = "README.md"
requires-python = ">=3.11"
dependencies = [
    # TODO: list runtime dependencies here.
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[dependency-groups]
dev = [
    "pytest",
    "ruff",
]

[tool.ruff]
line-length = 100

[tool.ruff.lint]
# TODO: tune the rule set; this is a sane starting point.
select = ["E", "F", "I"]

[tool.pytest.ini_options]
testpaths = ["tests"]
