# Copy to .env (gitignored, never commit). The companion plugin denies
# reads/writes to .env*.
#
# Uncomment and fill in the values you need. Lines below are examples only.

# Contact email for the Unpaywall API (open-access PDF lookups).
# UNPAYWALL_EMAIL=you@example.org

# Generic third-party API keys (replace placeholders with real secrets).
# OPENALEX_API_KEY=your-openalex-key
# NCBI_API_KEY=your-ncbi-entrez-key
# ZOTERO_API_KEY=your-zotero-key
# ZOTERO_USER_ID=0000000
