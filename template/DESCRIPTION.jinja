Package: {{ project_slug }}
Title: {{ project_name }}
Version: 0.0.0.9000
Authors@R:
    person(given = "{{ author }}",
           family = "",
           role = c("aut", "cre"))
Description: Reproducible analysis project for {{ project_name }}.
    Pipeline orchestrated with {targets} and dependencies pinned with renv.
    Replace this paragraph with a one-sentence description of the project.
License: {{ license }}
Encoding: UTF-8
Roxygen: list(markdown = TRUE)
RoxygenNote: 7.3.2
Imports:
    targets,
    renv
Suggests:
    testthat (>= 3.0.0),
    quarto
Config/testthat/edition: 3
