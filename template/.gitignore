# .gitignore — keep secrets, caches, and derived artifacts out of version control.

# --- Python environments / caches ------------------------------------------
.venv/
__pycache__/
*.pyc

# --- R / RStudio / renv ----------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Ruserdata
# Track renv settings + lockfile (generated by `make setup`), but never the
# restored library or local caches.
renv/library/
renv/local/
renv/cellar/
renv/staging/
# renv.lock IS committed (absolute reproducibility): it is intentionally NOT ignored.

# --- targets store + derived data (regenerable; rebuilt by `make reset`) ----
_targets/
data/derived/*
!data/derived/.gitkeep

# --- Agent-only caches (derived, disposable) -------------------------------
_agent_cache/
_agent_private/

# --- Meta-learner transient state (machine-local; the durable learning/*.md
#     files and learning/sessions/ handoffs ARE committed) --------------------
.claude/state/
learning/queue/

# --- Local data-connection config (keep the committed example) -------------
config.yml
!config.example.yml

# --- Secrets ---------------------------------------------------------------
.env
.env.*
!.env.example

# --- Scratch / temporary work ----------------------------------------------
# Ignore everything under tmp/ but keep the directory placeholder.
tmp/*
!tmp/.gitkeep

# --- Derived outputs -------------------------------------------------------
# Ignore generated artifacts under outputs/ but keep the placeholder and the
# documented layout contract.
outputs/*
!outputs/.gitkeep
!outputs/OUTPUT_LAYOUT.md

# --- RAG / context indices (derived) ---------------------------------------
# llms.txt and search indices are regenerated, never hand-edited or committed.
llms.txt
.rag/
*.index
*.faiss

# --- Logs ------------------------------------------------------------------
*.log

# --- Node / Quarto / misc tooling ------------------------------------------
node_modules/
.quarto/

# --- Office / editor lock files (e.g. ~$report.docx) ------------------------
~$*
