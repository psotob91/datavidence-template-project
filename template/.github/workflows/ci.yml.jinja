name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  anti-placeholder:
    name: Anti-placeholder scan
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v7
      - uses: actions/setup-python@v6
        with:
          python-version: "3.12"
      - name: Check for unfilled template placeholders
        run: python scripts/check_placeholders.py

  gitleaks:
    name: Secret scan
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v7
        with:
          fetch-depth: 0
      - name: Run gitleaks
        uses: gitleaks/gitleaks-action@v2
        env:
          GITHUB_TOKEN: ${{ '{{' }} secrets.GITHUB_TOKEN {{ '}}' }}
{% if analysis_stack == 'r' %}
  r-repro:
    name: R reproducibility (lint + reset + rebuild)
    runs-on: ubuntu-latest
    # Reproducibility gate: a clean checkout restores the pinned env, destroys all
    # derived artifacts, and rebuilds every result from input + code alone.
    steps:
      - uses: actions/checkout@v7
      - uses: r-lib/actions/setup-r@v2
        with:
          use-public-rspm: true
      - uses: r-lib/actions/setup-renv@v2
      - name: Lint
        run: make lint
      - name: Reset + full rebuild (make reset && make all)
        run: make reset && make all
{% elif analysis_stack == 'python' %}
  python-checks:
    name: Python lint + tests
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v7
      - name: Install uv
        uses: astral-sh/setup-uv@v8.2.0
      - name: Sync environment
        run: uv sync --frozen
      - name: Lint
        run: uv run ruff check .
      - name: Test
        run: uv run pytest
{% endif %}
